---
import { OWNER, CONTACT } from '../../lib/constants';
---

<section id="sobre" class="section-padding bg-white">
  <div class="container-main">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div class="aspect-square rounded-3xl bg-gradient-to-br from-primary-lighter via-primary-light to-accent overflow-hidden shadow-2xl shadow-primary/20">
          <div class="absolute inset-0 flex items-center justify-center text-center p-8">
            <div><div class="w-32 h-32 mx-auto mb-6 rounded-full bg-white/30 backdrop-blur flex items-center justify-center"><svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg></div><p class="text-white font-heading text-3xl font-semibold">{OWNER.name}</p><p class="text-white/70 text-sm mt-2">{OWNER.role}</p></div>
          </div>
        </div>
      </div>
      <div>
        <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary font-medium text-sm rounded-full mb-4">Sobre Nos</span>
        <h2 class="section-title mb-6">Conheca a <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">{{STORE_SHORT_NAME}}</span></h2>
        <div class="space-y-4 text-gray-500 leading-relaxed">
          <p>{{ABOUT_TEXT_1}}</p>
          <p>{{ABOUT_TEXT_2}}</p>
          <p>{{ABOUT_TEXT_3}}</p>
        </div>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href={`${CONTACT.whatsappLink}?text=${encodeURIComponent('Ola! Quero conhecer a loja!')}`} target="_blank" rel="noopener noreferrer" class="btn-primary">Falar com {OWNER.name}</a>
          {CONTACT.instagramUrl && <a href={CONTACT.instagramUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary">Instagram</a>}
        </div>
      </div>
    </div>
  </div>
</section>
