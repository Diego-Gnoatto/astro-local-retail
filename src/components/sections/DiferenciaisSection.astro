---
import { DIFFERENTIALS } from '../../lib/constants';
---

<section class="section-padding bg-gradient-to-br from-primary-lighter via-white to-accent/10">
  <div class="container-main">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary font-medium text-sm rounded-full mb-4">{{DIFF_BADGE}}</span>
      <h2 class="section-title mb-4">{{STORE_SHORT_NAME}} e <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Diferente</span></h2>
      <p class="section-subtitle">{{DIFF_SUBTITLE}}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {DIFFERENTIALS.map((diff) => (
        <div class="text-center p-8 rounded-2xl bg-white shadow-sm border border-gray-100 hover:shadow-xl hover:shadow-primary/10 transition-all duration-300 hover:-translate-y-1">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-primary/10 flex items-center justify-center"><span class="text-3xl">{{DIFF_ICON}}</span></div>
          <h3 class="font-heading text-lg font-semibold text-dark mb-3">{diff.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{diff.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
