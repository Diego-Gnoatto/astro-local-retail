---
import { CATEGORIES, CONTACT } from '../../lib/constants';
---

<section id="colecao" class="section-padding bg-white">
  <div class="container-main">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary font-medium text-sm rounded-full mb-4">{{COLECTION_BADGE}}</span>
      <h2 class="section-title mb-4">Encontre Seu <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">Estilo</span></h2>
      <p class="section-subtitle">{{COLECTION_SUBTITLE}}</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {CATEGORIES.map((cat) => (
        <div class="card group cursor-pointer overflow-hidden">
          <div class="aspect-[4/5] bg-gradient-to-br from-primary-lighter to-primary-light relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="text-center"><div class="w-20 h-20 mx-auto rounded-full bg-white/30 backdrop-blur flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-500"><svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg></div><p class="text-white font-heading text-xl font-semibold">{cat.name}</p></div>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>
          <div class="p-6">
            <h3 class="font-heading text-xl font-semibold text-dark mb-2">{cat.name}</h3>
            <p class="text-gray-500 text-sm mb-4">{cat.description}</p>
            <a href={`${CONTACT.whatsappLink}?text=${encodeURIComponent(`Ola! Tenho interesse nas pecas de ${cat.name}!`)}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-primary font-medium text-sm hover:text-primary-dark transition-colors">Ver pecas <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
