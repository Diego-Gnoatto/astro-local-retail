---
import { CONTACT } from '../../lib/constants';
---

<section class="section-padding bg-gradient-to-br from-primary via-primary-dark to-dark relative overflow-hidden">
  <div class="relative max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">{{CTA_HEADLINE}}</h2>
    <p class="text-lg md:text-xl text-white/80 mb-10 max-w-2xl mx-auto">{{CTA_SUBHEADLINE}}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={`${CONTACT.whatsappLink}?text=${encodeURIComponent('Ola! Quero saber mais!')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-10 py-4 bg-white text-primary font-bold rounded-full transition-all duration-300 hover:shadow-2xl hover:shadow-white/20 hover:-translate-y-0.5 text-lg">Chamar no WhatsApp</a>
      {CONTACT.instagramUrl && <a href={CONTACT.instagramUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-10 py-4 border-2 border-white/30 text-white font-bold rounded-full transition-all duration-300 hover:bg-white/10 hover:border-white/50 text-lg">Seguir no Instagram</a>}
    </div>
  </div>
</section>
